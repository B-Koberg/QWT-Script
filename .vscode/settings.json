{
    "files.autoSave": "off",
    "editor.wordWrap": "on",
    //"editor.wordWrapColumn": 80,
    //"editor.rulers": [80],
    "latex-workshop.formatting.latex": "latexindent",
    "latex-workshop.latex.autoClean.run": "off",
    "latex-workshop.latex.clean.method": "glob",
    "latex-workshop.latex.clean.subfolder.enabled": true,
    "latex-workshop.latex.clean.fileTypes": [
        "*.aux",
        "*.auxlock",
        "*.bbl",
        "*.bcf",
        "*.blg",
        "*.brf",
        "*.dvi",
        "*.ilg",
        "*.ist",
        "*.idx",
        "*.ind",
        "*.lof",
        "*.lot",
        "*.log",
        "*.nav",
        "*.out",
        "*.snm",
        "*.thm",
        "*.run.xml",
        "*.toc",
        "*.vrb",
        "*.xdv",
        "*.acn",
        "*.acr",
        "*.alg",
        "*.glg",
        "*.glo",
        "*.gls",
        "*.fls",
        "*.fdb_latexmk"
    ],
    "files.trimTrailingWhitespace": true,

    // Copilot-Einstellungen für LaTeX-Dateien
    "[latex]": {
        "editor.defaultFormatter": "James-Yu.latex-workshop",
        "editor.formatOnSave": true
    },

    // Alternative: Copilot komplett für diesen Workspace deaktivieren
    "github.copilot.enable": true,
    "github.copilot.editor.enableAutoCompletions": true,
    "editor.inlineSuggest.enabled": true,

    // Spell Checker Einstellungen
    "cSpell.words": [
        "actinides",
        "cosmogenic",
        "cryocoolers",
        "DARWIN",
        "electroluminescence",
        "ENDF",
        "Geant",
        "GeV",
        "MeV",
        "neutrinoless",
        "photodetectors",
        "polyethylene",
        "ppb",
        "radiogenic",
        "WIMPs",
        "xenon",
        "XENON",
        "XLZD",
        "ZEPLIN"
    ],
    "cSpell.language": "en,de",
    "cSpell.ignoreRegExpList": [
        "\\\\[a-zA-Z]+\\{[^}]*\\}",
        "\\$[^$]*\\$",
        "\\\\cite\\{[^}]*\\}",
        "\\\\ref\\{[^}]*\\}",
        "\\\\label\\{[^}]*\\}"
    ]
}
